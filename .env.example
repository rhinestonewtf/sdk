# Optional, used to run the integration tests. Live tests default to dev.
INTEGRATION_TARGET=dev
INTEGRATION_RHINESTONE_API_KEY=
INTEGRATION_RHINESTONE_API_RELAYER_KEY=
# Optional endpoint override. The default dev endpoint is selected from
# INTEGRATION_TARGET.
INTEGRATION_ORCHESTRATOR_URL=
# Optional, required only for funded specs (non-sponsored cross-chain,
# spending-limit policies). The address derived from this key must hold testnet
# native + USDC on the integration chains.
INTEGRATION_FUNDER_PRIVATE_KEY=
