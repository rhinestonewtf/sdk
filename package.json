{
  "private": true,
  "scripts": {
    "build": "bun run clean && tsc && tsc-esm-fix --target=src/dist",
    "clean": "rimraf src/dist",
    "test": "bun run test:unit",
    "test:unit": "vitest --config vitest.config.unit.ts",
    "test:contract": "bun run scripts/contract/run.ts",
    "test:coverage:core": "vitest --config vitest.config.core.ts --coverage --run",
    "test:coverage:pure": "vitest --config vitest.config.core.ts --coverage --run",
    "test:integration": "vitest --config vitest.config.integration.ts",
    "test:integration:smoke": "vitest --config vitest.config.integration.ts test/integration/scenarios/smoke.itest.ts",
    "test:integration:smoke:debug": "SDK_ITEST_DEBUG=1 vitest --config vitest.config.integration.ts test/integration/scenarios/smoke.itest.ts",
    "check": "biome check",
    "check:architecture": "bun run scripts/architecture/check.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tests.json",
    "test:types": "tsc --noEmit -p tsconfig.type-tests.json",
    "generate:reference:extract": "typedoc --options scripts/reference/typedoc.json",
    "generate:reference:render": "bun run scripts/reference/generate.ts",
    "generate:reference": "bun run generate:reference:extract && bun run generate:reference:render",
    "generate:wire": "bun run scripts/generate-wire-types.ts",
    "changeset": "changeset",
    "changeset:release": "bun run build && changeset publish",
    "changeset:version": "changeset version && bun run scripts/sync-version.ts",
    "size": "size-limit"
  },
  "workspaces": [
    "./src"
  ],
  "dependencies": {
    "viem": "^2.55.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@changesets/cli": "^2.28.1",
    "@size-limit/esbuild-why": "^11.2.0",
    "@size-limit/preset-small-lib": "^11.2.0",
    "@types/bun": "^1.2.8",
    "@vitest/coverage-v8": "3.1.2",
    "fast-check": "^4.9.0",
    "jose": "^6.2.2",
    "openapi-typescript": "^7.13.0",
    "rimraf": "^6.0.1",
    "size-limit": "^11.2.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.13",
    "tsc-esm-fix": "^3.1.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.8.2",
    "vitest": "^3.1.2"
  }
}
