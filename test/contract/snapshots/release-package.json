{
  "packageName": "@rhinestone/sdk",
  "entrypoints": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./actions": {
      "types": "./dist/src/actions/index.d.ts",
      "import": "./dist/src/actions/index.js"
    },
    "./actions/ecdsa": {
      "types": "./dist/src/actions/ecdsa.d.ts",
      "import": "./dist/src/actions/ecdsa.js"
    },
    "./actions/mfa": {
      "types": "./dist/src/actions/mfa.d.ts",
      "import": "./dist/src/actions/mfa.js"
    },
    "./actions/passkeys": {
      "types": "./dist/src/actions/passkeys.d.ts",
      "import": "./dist/src/actions/passkeys.js"
    },
    "./signing/passkeys": {
      "types": "./dist/src/signing/passkeys.d.ts",
      "import": "./dist/src/signing/passkeys.js"
    },
    "./actions/smart-sessions": {
      "types": "./dist/src/actions/smart-sessions.d.ts",
      "import": "./dist/src/actions/smart-sessions.js"
    },
    "./errors": {
      "types": "./dist/src/errors/index.d.ts",
      "import": "./dist/src/errors/index.js"
    },
    "./utils": {
      "types": "./dist/src/utils/index.d.ts",
      "import": "./dist/src/utils/index.js"
    },
    "./smart-sessions": {
      "types": "./dist/src/smart-sessions/index.d.ts",
      "import": "./dist/src/smart-sessions/index.js"
    },
    "./jwt-server": {
      "types": "./dist/src/jwt-server/index.d.ts",
      "import": "./dist/src/jwt-server/index.js"
    }
  },
  "runtimeExports": {
    ".": [
      "MULTI_FACTOR_VALIDATOR_ADDRESS",
      "OWNABLE_VALIDATOR_ADDRESS",
      "RhinestoneSDK",
      "SMART_SESSION_EMISSARY_ADDRESS",
      "WEBAUTHN_VALIDATOR_ADDRESS",
      "hyperCoreMainnet",
      "solanaMainnet",
      "tronMainnet"
    ],
    "./actions": ["deploy", "installModule", "uninstallModule"],
    "./actions/ecdsa": [
      "addOwner",
      "changeThreshold",
      "disable",
      "enable",
      "removeOwner"
    ],
    "./actions/mfa": [
      "changeThreshold",
      "disable",
      "enable",
      "removeSubValidator",
      "setSubValidator"
    ],
    "./actions/passkeys": [
      "addOwner",
      "changeThreshold",
      "disable",
      "enable",
      "removeOwner"
    ],
    "./signing/passkeys": [
      "generateCredentialId",
      "packSignature",
      "packSignatureV0",
      "parsePublicKey",
      "parseSignature"
    ],
    "./actions/smart-sessions": [
      "experimental_disable",
      "experimental_disableSession",
      "experimental_enable",
      "experimental_enableSession"
    ],
    "./errors": [
      "AccountConfigurationNotSupportedError",
      "AccountError",
      "ConflictError",
      "DefaultValidatorAlreadyInitializedError",
      "Eip712DomainNotAvailableError",
      "Eip7702AccountMustHaveEoaError",
      "Eip7702InitSignatureRequiredError",
      "Eip7702NotSupportedForAccountError",
      "EoaAccountMustHaveAccountError",
      "EoaSigningMethodNotConfiguredError",
      "EoaSigningNotSupportedError",
      "ExecutionError",
      "ExternalServiceTimeoutError",
      "FactoryArgsNotAvailableError",
      "ForbiddenError",
      "IndependentSigningNotSupportedError",
      "InsufficientLiquidityError",
      "InsufficientOwnerSignaturesError",
      "IntentFailedError",
      "InternalServerError",
      "InvalidOwnerSigningOptionsError",
      "InvalidSourceCallsError",
      "KeyScopeDeniedError",
      "MismatchedOwnerSignaturesError",
      "ModuleInstallationNotSupportedError",
      "NotFoundError",
      "OrchestratorError",
      "OrderPathRequiredForIntentsError",
      "OwnersFieldRequiredError",
      "QuoteNotInPreparedTransactionError",
      "RateLimitedError",
      "RelayerMarketUnavailableError",
      "SettlementExecutionError",
      "SettlementQuoteError",
      "SigningNotSupportedForAccountError",
      "SimulationFailedError",
      "UnauthorizedError",
      "UnknownOwnerError",
      "UnprocessableContentError",
      "UnsupportedChainError",
      "UnsupportedTokenError",
      "ValidationError",
      "WalletClientNoConnectedAccountError",
      "isAccountError",
      "isAuthError",
      "isExecutionError",
      "isOrchestratorError",
      "isRateLimited",
      "isRetryable",
      "isSimulationFailed",
      "isValidationError"
    ],
    "./utils": [
      "experimental_getModuleSetup",
      "experimental_getRhinestoneInitData",
      "experimental_getV0InitData",
      "toViewOnlyAccount",
      "walletClientToAccount",
      "wrapParaAccount"
    ],
    "./smart-sessions": [
      "ARG_POLICY_ADDRESS",
      "INTENT_EXECUTION_POLICY_ADDRESS",
      "SMART_SESSIONS_FALLBACK_TARGET_FLAG",
      "SMART_SESSIONS_FALLBACK_TARGET_SELECTOR_FLAG",
      "SMART_SESSION_EMISSARY_ADDRESS",
      "SMART_SESSION_EMISSARY_ADDRESS_DEV",
      "SPENDING_LIMITS_POLICY_ADDRESS",
      "SUDO_POLICY_ADDRESS",
      "TIME_FRAME_POLICY_ADDRESS",
      "UNIVERSAL_ACTION_POLICY_ADDRESS",
      "USAGE_LIMIT_POLICY_ADDRESS",
      "VALUE_LIMIT_POLICY_ADDRESS",
      "getPermissionId",
      "getSessionData",
      "getSessionDetails",
      "isSessionEnabled",
      "toCrossChainPermissionInput",
      "toSession"
    ],
    "./jwt-server": [
      "SponsorshipDeniedError",
      "computeIntentInputDigest",
      "createAccessTokenHandler",
      "createExpressRouter",
      "createExtensionTokenHandler",
      "createJwtSigner",
      "jcsCanonicalise",
      "shouldSponsor"
    ]
  }
}
